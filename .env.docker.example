# =============================================================================
# .env para docker compose — copiar a `.env` y rellenar con valores reales:
#     cp .env.docker.example .env     (Linux)
#     Copy-Item .env.docker.example .env   (Windows PowerShell)
# Lo inyecta el contenedor del BACKEND (env_file); el ENGINE toma de aquí
# WHATSAPP_ENGINE_SECRET vía interpolación del compose.
#
# Solo están las variables que el código realmente usa. Las marcadas (OBLIGATORIA)
# bloquean el arranque del backend si faltan.
# =============================================================================

# ── DJANGO ───────────────────────────────────────────────────────────────────
# (OBLIGATORIA) genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

DEBUG=False
# Dominio(s) públicos + el servicio "frontend" para las requests internas:
ALLOWED_HOSTS=localhost,127.0.0.1,frontend
# Con DEBUG=False y un dominio real, pon aquí https://tudominio.com :
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://localhost:8000

# ── BASE DE DATOS (Postgres EXTERNO — no se levanta en compose) ───────────────
# DB_HOST: en el mismo host Windows/Mac -> host.docker.internal ;
#          Postgres administrado -> su endpoint real.
DB_NAME=bootwhatsapp
DB_USER=bootwhatsapp_user
DB_PASSWORD=            # (OBLIGATORIA) password del rol bootwhatsapp_user
DB_HOST=host.docker.internal
DB_PORT=5432

# ── WHATSAPP / META CLOUD API ────────────────────────────────────────────────
# Meta Developers -> tu App -> WhatsApp -> API Setup (token y phone_number_id),
# y Configuración básica (app secret). META_VERIFY_TOKEN es un valor libre que
# defines y repites en Meta -> Webhooks.
WHATSAPP_API_TOKEN=          # (OBLIGATORIA)
WHATSAPP_PHONE_NUMBER_ID=    # (OBLIGATORIA)
WHATSAPP_APP_SECRET=         # (OBLIGATORIA) valida la firma del webhook
META_VERIFY_TOKEN=           # (OBLIGATORIA) verificación del webhook

# ── IA ───────────────────────────────────────────────────────────────────────
# (OBLIGATORIA) Groq es el proveedor principal de texto -> https://console.groq.com/keys
GROQ_API_KEY=
# Together.ai: respaldo de texto + visión de imágenes (facturas DIAN, validación
# de documentos). Sin esta, el texto sigue por Groq pero NO se procesan imágenes.
TOGETHER_API_KEY=

# ── CIFRADO ──────────────────────────────────────────────────────────────────
# Cifra el access_token de cada conexión guardada en la BD.
# Genera: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# OJO: no la cambies si ya hay conexiones guardadas — quedarían ilegibles.
FERNET_KEY=

# ── ENGINE (Node) ────────────────────────────────────────────────────────────
# (OBLIGATORIA) secreto compartido backend<->engine. Cualquier string largo.
# Genera: python -c "import secrets; print(secrets.token_urlsafe(32))"
WHATSAPP_ENGINE_SECRET=

# ── OPCIONAL ─────────────────────────────────────────────────────────────────
# Solo si usas el gateway de Aliados (firma las integraciones). Si lo dejas
# vacío, el resto de la app funciona igual.
# Genera: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTEGRATION_SALT=
