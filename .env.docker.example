# =============================================================================
# .env para docker compose — copiar a `.env` y editar con secretos reales:
#     cp .env.docker.example .env
# Este archivo se inyecta en el contenedor del BACKEND vía `env_file: .env`,
# y el ENGINE lee WHATSAPP_ENGINE_SECRET desde acá vía interpolación de compose.
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO
# -----------------------------------------------------------------------------
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

DEBUG=False
# Lista separada por comas. Incluí el dominio público + el nombre del servicio
# del frontend para que las requests internas no caigan.
ALLOWED_HOSTS=localhost,127.0.0.1,frontend
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://localhost:8000

# -----------------------------------------------------------------------------
# BASE DE DATOS — Postgres EXTERNO (no se levanta en compose)
# -----------------------------------------------------------------------------
# Si Postgres corre en el HOST Windows/Mac:    DB_HOST=host.docker.internal
# Si es un Postgres administrado (RDS/DO/...): DB_HOST=tu.endpoint.com
# Si vive en otro container fuera del compose: nombre del container en su red
DB_NAME=bootwhatsapp
DB_USER=bootwhatsapp_user
DB_PASSWORD=
DB_HOST=host.docker.internal
DB_PORT=5432
DB_CONN_MAX_AGE=60

# -----------------------------------------------------------------------------
# WHATSAPP META API (Cloud)
# -----------------------------------------------------------------------------
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# -----------------------------------------------------------------------------
# AI (OpenAI-compatible — Groq, OpenAI, etc. — usado por chat/services/ai_service.py)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# INTEGRATION GATEWAY (Aliados)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------------
INTEGRATION_SALT=

# -----------------------------------------------------------------------------
# FERNET (cifra access_token de WhatsAppConnection en DB)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Cambiar esto desencripta MAL las conexiones existentes — guardalo seguro.
# -----------------------------------------------------------------------------
FERNET_KEY=

# -----------------------------------------------------------------------------
# WHATSAPP ENGINE (Node)
# Mismo valor en backend y engine. Cualquier string aleatorio largo sirve.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------------
WHATSAPP_ENGINE_SECRET=
